# === VesteZap — produção ===
# Copie como .env.production e preencha.

DOMAIN=vestezap.com.br

APP_NAME=VesteZap
APP_ENV=production
APP_DEBUG=false
APP_KEY=
APP_URL=https://${DOMAIN}
FRONTEND_URL=https://${DOMAIN}

# Database (MySQL)
DB_DATABASE=vestezap
DB_USERNAME=vestezap
DB_PASSWORD=changeme_app
DB_ROOT_PASSWORD=changeme_root

# Mail (Resend via SMTP) — porta 465 exige ssl (na 465 NAO use tls/STARTTLS)
MAIL_MAILER=smtp
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_ENCRYPTION=ssl
MAIL_USERNAME=resend
MAIL_PASSWORD=          # API key do Resend (re_...)
MAIL_FROM_ADDRESS=no-reply@dynasolutions.com.br
MAIL_FROM_NAME=VesteZap

LOG_LEVEL=notice

# reCAPTCHA v3 (console: https://www.google.com/recaptcha/admin)
# Registrar o domínio acima. Site key vai no build do frontend; Secret no backend.
# Sem valores reais, o cadastro de loja falha com "Verificação reCAPTCHA falhou".
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
